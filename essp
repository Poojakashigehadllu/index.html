<!DOCTYPE html>
<html>
<head>
  <title>ESP LED Control</title>
</head>
<body style="text-align:center; margin-top:100px;">

  <h1>ESP8266 LED</h1>

  <button onclick="toggleLED()" style="padding:20px; font-size:20px;">
    Toggle LED
  </button>

  <script>
    let state = false;

    function toggleLED() {
      state = !state;

      if(state) {
       fetch("https://fredda-sarkless-recognizably.ngrok-free.dev/on");
      } else {
       fetch("https://fredda-sarkless-recognizably.ngrok-free.dev/off");
      }
    }
  </script>

</body>
</html>
